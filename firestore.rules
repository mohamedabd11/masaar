rules_version = '2';
// ══════════════════════════════════════════════════════════
// firestore.rules — قواعد أمان Firestore
// انسخ هذه القواعد إلى Firebase Console:
//   https://console.firebase.google.com → Firestore → Rules
// ══════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── دوال مساعدة ──
    function isAuth() {
      return request.auth != null;
    }

    function myUid() {
      return request.auth.uid;
    }

    function myEmail() {
      return request.auth.token.email;
    }

    // قراءة بيانات المستخدم الحالي من مجموعة users
    function myUserData() {
      return get(/databases/$(database)/documents/users/$(myUid())).data;
    }

    function isAdmin() {
      return isAuth() && myUserData().role == 'admin';
    }

    function isEditor() {
      return isAuth() && myUserData().role == 'editor';
    }

    function isViewer() {
      return isAuth() && myUserData().role == 'viewer';
    }

    function isActiveUser() {
      let data = myUserData();
      return isAuth() && data.deleted != true && data.active != false;
    }

    function canWrite() {
      let data = myUserData();
      return isAuth() && data.deleted != true && data.active != false
        && (data.role == 'admin' || data.role == 'editor' || data.role == 'custom');
    }

    // ══════════════════════════════════════════
    // مجموعة entries — السندات والعهدة والمصروفات
    // ══════════════════════════════════════════
    match /entries/{entryId} {
      // Admin يقرأ كل شيء — المحررون/المخصصون يقرأون فقط سجلاتهم
      allow read: if isAuth() && isActiveUser() && (
        isAdmin() || resource.data.createdBy == myEmail()
      );

      // إنشاء: فقط للمستخدمين النشطين القادرين على الكتابة
      allow create: if canWrite() && (
        // التحقق أن createdBy يطابق بريد المستخدم الحالي
        request.resource.data.createdBy == myEmail()
      );

      // تعديل وحذف: Admin فقط
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ══════════════════════════════════════════
    // مجموعة users — حسابات المستخدمين
    // ══════════════════════════════════════════
    match /users/{userId} {
      // كل مستخدم يقرأ بياناته الخاصة — Admin يقرأ الكل
      allow read: if isAuth() && (
        myUid() == userId || isAdmin()
      );

      // إنشاء: Admin أو المستخدم الأول (لا يوجد حسابات بعد)
      allow create: if isAuth() && (
        isAdmin() ||
        // السماح بإنشاء أول حساب admin
        !exists(/databases/$(database)/documents/users/$(userId))
      );

      // تعديل وحذف: Admin فقط
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ══════════════════════════════════════════
    // مجموعة settings — إعدادات النظام
    // ══════════════════════════════════════════
    match /settings/{docId} {
      // كل المستخدمين المفعّلين يقرأون
      allow read: if isAuth() && isActiveUser();
      // Admin فقط يعدّل
      allow write: if isAdmin();
    }

    // ══════════════════════════════════════════
    // مجموعة shifts — إقفالات الوردية
    // ══════════════════════════════════════════
    match /shifts/{shiftId} {
      allow read:   if isAuth() && isActiveUser();
      allow create: if isAuth() && isActiveUser();
      allow update, delete: if isAdmin();
    }

    // ══════════════════════════════════════════
    // مجموعة auditLog — سجل المراجعة
    // ══════════════════════════════════════════
    match /auditLog/{logId} {
      // Admin فقط يقرأ سجل المراجعة
      allow read: if isAdmin();
      // أي مستخدم نشط يضيف (للتسجيل التلقائي)
      allow create: if isAuth() && isActiveUser();
      // لا يمكن تعديل أو حذف سجلات المراجعة
      allow update, delete: if false;
    }

  }
}
