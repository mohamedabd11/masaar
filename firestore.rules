rules_version = '2';
// ══════════════════════════════════════════════════════════
// firestore.rules — قواعد أمان Firestore
// انسخ هذه القواعد إلى Firebase Console:
//   https://console.firebase.google.com → Firestore → Rules
// ══════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // استدعاء واحد لبيانات المستخدم — يُخزَّن في متغير محلي لتجنب قراءتين
    function ud() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // ══════════════════════════════════════════
    // مجموعة entries — السندات والعهدة والمصروفات
    // ══════════════════════════════════════════
    match /entries/{entryId} {
      allow read: if request.auth != null && (
        let d = ud();
        d.deleted != true && d.active != false &&
        (d.role == 'admin' || d.role == 'manager' || resource.data.createdBy == request.auth.token.email)
      );

      allow create: if request.auth != null && (
        let d = ud();
        d.deleted != true && d.active != false &&
        (d.role == 'admin' || d.role == 'manager' || d.role == 'editor' || d.role == 'custom') &&
        request.resource.data.createdBy == request.auth.token.email
      );

      allow update: if request.auth != null && ud().role == 'admin';
      allow delete: if request.auth != null && ud().role == 'admin';
    }

    // ══════════════════════════════════════════
    // مجموعة users — حسابات المستخدمين
    // ══════════════════════════════════════════
    match /users/{userId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId || ud().role == 'admin'
      );

      allow create: if request.auth != null && (
        ud().role == 'admin' ||
        !exists(/databases/$(database)/documents/users/$(userId))
      );

      allow update: if request.auth != null && ud().role == 'admin';
      allow delete: if request.auth != null && ud().role == 'admin';
    }

    // ══════════════════════════════════════════
    // مجموعة settings — إعدادات النظام
    // ══════════════════════════════════════════
    match /settings/{docId} {
      allow read: if request.auth != null && (
        let d = ud();
        d.deleted != true && d.active != false
      );
      allow write: if request.auth != null && ud().role == 'admin';
    }

    // ══════════════════════════════════════════
    // مجموعة shifts — إقفالات الوردية
    // ══════════════════════════════════════════
    match /shifts/{shiftId} {
      allow read: if request.auth != null && (
        let d = ud();
        d.deleted != true && d.active != false
      );
      allow create: if request.auth != null && (
        let role = ud().role;
        role == 'admin' || role == 'manager'
      );
      allow update, delete: if request.auth != null && ud().role == 'admin';
    }

    // ══════════════════════════════════════════
    // مجموعة auditLog — سجل المراجعة
    // ══════════════════════════════════════════
    match /auditLog/{logId} {
      allow read: if request.auth != null && ud().role == 'admin';
      allow create: if request.auth != null && (
        let d = ud();
        d.deleted != true && d.active != false &&
        request.resource.data.performedBy == request.auth.token.email
      );
      allow update, delete: if false;
    }

  }
}
